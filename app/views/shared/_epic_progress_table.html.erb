<% if epic_progress_presenter.any_unestimated_issues? %>
  <div class="alert custom-alert custom-alert-danger d-flex align-items-center rounded-3 p-3 mb-4" role="alert">
    <span class="material-symbols-outlined fs-4 me-3">error</span>
    <div>
      <h4 class="alert-heading h6 fw-bold mb-1 font-manrope">Estimation Warning</h4>
      <p class="mb-0 small"><%= "There are #{epic_progress_presenter.unestimated_issues_count} issues without points. This can affect progress measurement." %></p>
    </div>
  </div>
<% end %>

<table class="table table-hover table-sm mb-0">
  <thead>
    <tr>
      <th scope="col">Total Points</th>
      <th scope="col">Completed Points</th>
      <th scope="col">Remaining Points</th>
      <th scope="col">Earned Value</th>
      <th scope="col">Remaining Value</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td class="font-monospace small fw-bold text-dark"><%= epic_progress_presenter.total_points %></td>
      <td class="font-monospace small fw-bold text-success"><%= epic_progress_presenter.completed_points %></td>
      <td class="font-monospace small fw-bold text-secondary"><%= epic_progress_presenter.remaining_points %></td>
      <td class="font-monospace small fw-bold text-primary"><%= epic_progress_presenter.earned_value %></td>
      <td class="font-monospace small fw-bold text-info"><%= "#{epic_progress_presenter.remaining_earned_value}%" %></td>
    </tr>
  </tbody>
</table>
