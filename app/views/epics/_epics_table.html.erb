<table class="table table-hover mb-0">
  <thead>
    <tr>
      <th style="width: 80px;">#</th>
      <th style="width: 160px;">Epic Key</th>
      <th>Summary</th>
      <th style="width: 140px;">Issues</th>
    </tr>
  </thead>
  <tbody>
    <% epics.each.with_index(1) do |epic, index| %>
      <tr>
        <td class="small fw-medium text-secondary"><%= index %></td>
        <td><span class="project-badge"><%= epic.key %></span></td>
        <td>
          <div class="d-flex align-items-center gap-3">
            <%= link_to epic.summary, project_epic_path(project_id: epic.project_key, id: epic.key), class: "fw-bold text-dark text-decoration-none hover-primary" %>
          </div>
        </td>
        <td>
          <%= link_to project_epic_issues_path(project_id: epic.project_key, epic_id: epic.key), class: "epic-link d-inline-flex align-items-center gap-1" do %>
            <span>Issues</span>
            <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
