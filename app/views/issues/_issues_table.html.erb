<table class="table table-hover mb-0">
  <thead>
    <tr>
      <th scope="col" style="width: 50px;">#</th>
      <th scope="col" style="width: 120px;">Issue Key</th>
      <th scope="col">Summary</th>
      <th scope="col" style="width: 150px;">Labels</th>
      <th scope="col" style="width: 100px;">Status</th>
      <th scope="col" class="text-center" style="width: 80px;">Points</th>
      <th scope="col" style="width: 140px;">Finish Date</th>
    </tr>
  </thead>
  <tbody>
    <% issues.each.with_index(1) do |issue, index| %>
      <tr>
        <td class="text-secondary fw-medium"><%= index %></td>
        <td class="font-monospace text-primary fw-bold"><%= issue.key %></td>
        <td class="fw-semibold"><%= issue.summary %></td>
        <td>
          <% if issue.labels.present? %>
            <span class="label-pill"><%= issue.labels %></span>
          <% end %>
        </td>
        <td>
          <span class="d-flex align-items-center small fw-bold text-secondary">
            <span class="status-dot bg-secondary border"></span>
            <%= issue.status %>
          </span>
        </td>
        <td class="text-center fw-bold"><%= issue.points %></td>
        <td class="text-secondary small"><%= issue.finish_date&.strftime("%d %b %Y") %></td>
      </tr>
    <% end %>
  </tbody>
</table>
