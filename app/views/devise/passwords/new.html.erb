<div class="d-flex align-items-center justify-content-center w-100 mt-5">
  <div class="login-card overflow-hidden">
    <div class="aspirational-banner p-4 p-md-5 text-center">
      <h2 class="h4 font-manrope fw-bold text-dark mb-2">
        Recover Password
      </h2>
      <p class="small text-muted mb-0 mx-auto" style="max-width: 280px; line-height: 1.5;">
        Securely reset your Jira Project Estimator credentials
      </p>
    </div>

    <div class="p-4 p-md-5">
      <div class="text-center mb-4">
        <h1 class="h3 font-manrope fw-bold mb-1">Forgot your password?</h1>
        <p class="small text-muted">We'll send you reset instructions</p>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= render 'devise/shared/error_messages', resource: resource %>

        <div class="mb-4">
          <%= f.label :email, class: 'label-heading' %>
          <%= f.email_field :email, autofocus: true, autocomplete: 'email', class: 'form-control-custom', placeholder: 'name@company.com', required: true %>
        </div>

        <div class="actions">
          <%= f.submit 'Send instructions', class: 'btn-primary-custom' %>
        </div>
      <% end %>

      <div class="mt-4 text-center">
        <%- if controller_name != 'sessions' %>
          <%= link_to 'Back to Log in', new_session_path(resource_name), class: 'small fw-bold text-decoration-none text-primary' %>
        <% end %>
      </div>
    </div>
  </div>
</div>
